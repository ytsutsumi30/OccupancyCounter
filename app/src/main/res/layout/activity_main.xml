<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:context=".MainActivity">

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 上部の半透明オーバーレイ: 滞在人数 -->
    <LinearLayout
        android:id="@+id/topOverlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#99000000"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/labelOccupancy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_occupancy"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/txtCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#00E676"
            android:textSize="96sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/txtRaw"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#BBFFFFFF"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- 下部の半透明オーバーレイ: ステータス -->
    <LinearLayout
        android:id="@+id/bottomOverlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#99000000"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/txtStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:text="@string/status_initializing" />

        <TextView
            android:id="@+id/txtServer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#BBFFFFFF"
            android:textSize="12sp"
            android:layout_marginTop="4dp"
            android:text="@string/label_server_off" />

        <TextView
            android:id="@+id/txtTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#BBFFFFFF"
            android:textSize="12sp"
            android:layout_marginTop="4dp"
            android:text="--:--:--" />

        <Button
            android:id="@+id/btnSettings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="8dp"
            android:text="@string/title_settings" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
